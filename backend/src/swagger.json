{
  "openapi": "3.0.0",
  "info": {
    "title": "API Genoma - Sistema de Laboratório Genómico",
    "description": "API RESTful para gerenciamento de laboratório genómico com pacientes, testes, pedidos e resultados",
    "version": "1.0.0",
    "contact": {
      "name": "Support",
      "email": "support@genoma.lab"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Servidor de desenvolvimento"
    },
    {
      "url": "https://api.genoma.lab",
      "description": "Servidor de produção"
    }
  ],
  
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Paciente": {
        "type": "object",
        "required": ["nome", "data_nascimento"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID único do paciente"
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome completo do paciente"
          },
          "data_nascimento": {
            "type": "string",
            "format": "date",
            "description": "Data de nascimento"
          },
          "genero": {
            "type": "string",
            "enum": ["M", "F", "Outro"],
            "description": "Gênero do paciente"
          },
          "nif": {
            "type": "string",
            "pattern": "^\\d{9}$",
            "description": "Número de Identificação Fiscal (9 dígitos)"
          },
          "telemovel": {
            "type": "string",
            "description": "Número de telemóvel"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email do paciente"
          },
          "morada": {
            "type": "string",
            "description": "Endereço do paciente"
          },
          "ativo": {
            "type": "boolean",
            "default": true,
            "description": "Indica se o paciente está ativo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Data de criação do registro"
          }
        }
      },
      "Teste": {
        "type": "object",
        "required": ["nome", "preco"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome do teste genómico"
          },
          "preco": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "description": "Preço do teste em euros"
          },
          "descricao": {
            "type": "string",
            "description": "Descrição detalhada do teste"
          },
          "ativo": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "PedidoExame": {
        "type": "object",
        "required": ["paciente_id", "medico_id", "teste_id"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "paciente_id": {
            "type": "string",
            "format": "uuid"
          },
          "medico_id": {
            "type": "string",
            "format": "uuid"
          },
          "teste_id": {
            "type": "string",
            "format": "uuid"
          },
          "empresa_id": {
            "type": "string",
            "format": "uuid"
          },
          "data_pedido": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "Pendente",
              "Colhido",
              "Em Análise",
              "Concluído",
              "Cancelado"
            ],
            "default": "Pendente"
          },
          "notas_clinicas": {
            "type": "string"
          },
          "ativo": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "description": "Mensagem de erro"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "Medico": {
        "type": "object",
        "required": ["nome", "email", "password", "num_ordem"],
        "properties": {
          "utilizador_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID único do médico (mesmo ID do utilizador)"
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome completo do médico"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email do médico"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do médico"
          },
          "num_ordem": {
            "type": "string",
            "maxLength": 20,
            "description": "Número da ordem dos médicos"
          },
          "especialidade": {
            "type": "string",
            "maxLength": 100,
            "description": "Especialidade médica"
          },
          "perfil_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID do perfil do utilizador"
          },
          "empresa_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID da empresa associada"
          },
          "ativo": {
            "type": "boolean",
            "default": true,
            "description": "Indica se o médico está ativo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Data de criação do registro"
          }
        }
      },
      "Utilizador": {
        "type": "object",
        "required": ["nome", "email", "password"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID único do utilizador"
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome completo do utilizador"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email do utilizador"
          },
          "telefone": {
            "type": "string",
            "description": "Telefone do utilizador"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 6,
            "description": "Palavra-passe do utilizador"
          },
          "perfil_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID do perfil do utilizador"
          },
          "empresa_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID da empresa associada"
          },
          "ativo": {
            "type": "boolean",
            "default": true,
            "description": "Indica se o utilizador está ativo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Data de criação do registro"
          }
        }
      },
      "Empresa": {
        "type": "object",
        "required": ["nome"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID único da empresa"
          },
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "description": "Nome da empresa"
          },
          "morada": {
            "type": "string",
            "description": "Morada da empresa"
          },
          "codigo_postal": {
            "type": "string",
            "maxLength": 20,
            "description": "Código postal"
          },
          "telefone": {
            "type": "string",
            "maxLength": 20,
            "description": "Telefone da empresa"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email da empresa"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Data de criação do registro"
          }
        }
      }
    }
  },
  
  "paths": {
    "/health": {
      "get": {
        "summary": "Verificar saúde da API",
        "description": "Endpoint para verificar se a API está operacional",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "API está operacional",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "API está operacional"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/medicos": {
      "get": {
        "summary": "Listar médicos",
        "description": "Obtém lista de médicos cadastrados",
        "tags": ["Médicos"],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de médicos obtida com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Medico"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      },
      "post": {
        "summary": "Criar novo médico",
        "tags": ["Médicos"],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Medico"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Médico criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
