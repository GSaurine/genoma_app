            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Medico"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Médico atualizado com sucesso"
          }
        }
      },
      "delete": {
        "summary": "Remover médico",
        "tags": ["Médicos"],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "utilizadorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Médico removido com sucesso"
          }
        }
      }
